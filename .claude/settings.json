{
  "permissions": {
    "deny": ["Bash(gh issue delete*)"]
  },
  "allowedTools": [
    "Edit",
    "Write",
    "Bash(git add*)",
    "Bash(git commit*)",
    "Bash(git push*)",
    "Bash(git checkout*)",
    "Bash(git pull*)",
    "Bash(git fetch*)",
    "Bash(git branch*)",
    "Bash(git status*)",
    "Bash(git diff*)",
    "Bash(git log*)",
    "Bash(git merge*)",
    "Bash(git tag*)",
    "Bash(git show*)",
    "Bash(git stash list*)",
    "Bash(git -C * log *)",
    "Bash(git -C * status *)",
    "Bash(git -C * diff *)",
    "Bash(git -C * show *)",
    "Bash(git -C * branch *)",
    "Bash(git -C * ls-tree *)",
    "Bash(git -C * ls-files *)",
    "Bash(git -C * worktree list*)",
    "Bash(git -C * add *)",
    "Bash(git -C * commit *)",
    "Bash(git -C * push *)",
    "Bash(git -C * fetch *)",
    "Bash(git -C * pull *)",
    "Bash(git -C * rebase *)",
    "Bash(git -C * merge *)",
    "Bash(git -C * checkout *)",
    "Bash(git -C * reset *)",
    "Bash(git -C * rm *)",
    "Bash(git-cliff *)",
    "Bash(gh issue*)",
    "Bash(gh pr*)",
    "Bash(node --test*)",
    "Bash(DB_PATH=*)",
    "Bash(MODEL_NAME=*)",
    "Bash(node -e*)",
    "Bash(npm test*)",
    "Bash(npm install*)",
    "Bash(npm run*)",
    "Bash(grep*)",
    "Bash(find*)",
    "Bash(ls*)",
    "Bash(wc*)",
    "Bash(mkdir*)",
    "Bash(cat*)",
    "Bash(echo*)",
    "Bash(head*)",
    "Bash(tail*)",
    "Bash(graphify query *)",
    "Bash(graphify explain *)",
    "Bash(graphify path *)",
    "Bash(graphify benchmark)",
    "Bash(/Users/mg/.local/share/uv/tools/graphifyy/bin/python *)"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // empty' 2>/dev/null); echo \"$cmd\" | grep -q 'git.*push' && (cd /opt/moo-gpt && { last_tag=$(git describe --tags --abbrev=0 2>/dev/null || echo ''); if [ -n \"$last_tag\" ]; then git log \"${last_tag}..HEAD\" --oneline 2>&1; else git log --oneline -20 2>&1; fi; } | tee /tmp/unreleased-commits.txt) || true",
            "statusMessage": "git-cliff: unreleased changes prüfen...",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
