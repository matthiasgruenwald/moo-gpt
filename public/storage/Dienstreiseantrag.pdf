/JS (function SYS_CB_HDL_CLR\(name,bNeedsColouredMustFillBorder\)\r{\r    if\(bNeedsColouredMustFillBorder\)\r    {    getField\(name\).strokeColor=color.red;\r        }\r        else\r    	{    getField\(name\).strokeColor=getBorderColor\(name\);\r        }\r    return bNeedsColouredMustFillBorder;\r}\r)
