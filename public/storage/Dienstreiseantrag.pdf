/JS (function SYS_CB_HDL_STATE\(\)\r{\r    if\(false==SYS_IS_MUFI_CB\(SYS_CB_HDL_STATE.arguments[0]\)\) return false;\r    var obj=getField\(SYS_CB_HDL_STATE.arguments[0]\);\r    if\("Yes"==obj.value\) return false;\r    if\(true==obj.readonly\) return false;\r    if\(display.hidden==obj.display\) return false;\r    for\(var i=1;i<SYS_CB_HDL_STATE.arguments.length;i++\)\r    {   if\("Yes"==getField\(SYS_CB_HDL_STATE.arguments[i]\).value\)\r    	{   return false;\r        }\r    }\r    return true;\r}\r)
>>
endobj
